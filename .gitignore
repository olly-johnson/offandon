# typescript
*.tsbuildinfo
next-env.d.ts

# raw source material for methodology extraction.
# may contain client-identifying info (real names, locations, story banks).
# the distilled, generic methodology lives in docs/methodology/.
# remove this line if you want to track the source files in the repo.
/examples/

# per-client source folders consumed by scripts/ingest:* (BO-042).
# contain confidential brand briefs, story banks, transcripts, viral references.
# the distilled per-user data lives in supabase tables (voice_dna, client_assets,
# user_memories, user_methodology) and is reachable via the app's RLS policies.
/clients/

certificates