# Supabase project — populate from Settings > API in the Supabase dashboard.
# .env.local should hold the real values and is gitignored.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only. Bypasses RLS; never expose to the browser, never NEXT_PUBLIC_-prefix.
# REQUIRED by the Inngest worker (no end-user JWT in that context) and any
# programmatic admin path. Get it from Supabase dashboard > Settings > API.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic API key for the production LLM clients (Voice DNA + Scripts).
# Server-only. Pinned to claude-sonnet-4-6 in code.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Inngest credentials for production (queueing background jobs).
# Local dev: not required if running `npx inngest-cli@latest dev`.
# Get both from inngest.com after creating the app.
INNGEST_EVENT_KEY=your-inngest-event-key
INNGEST_SIGNING_KEY=your-inngest-signing-key

# Optional. debug | info | warn | error. Defaults: production=info, otherwise=debug.
# LOG_LEVEL=debug
