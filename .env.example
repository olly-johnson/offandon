# Supabase project — populate from Settings > API in the Supabase dashboard.
# .env.local should hold the real values and is gitignored.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only. Bypasses RLS; never expose to the browser, never NEXT_PUBLIC_-prefix.
# REQUIRED by the Inngest worker (no end-user JWT in that context) and any
# programmatic admin path. Get it from Supabase dashboard > Settings > API.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic API key for the production LLM clients (Voice DNA + Scripts).
# Server-only. Pinned to claude-sonnet-4-6 in code.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Inngest credentials.
#
# Local dev: set INNGEST_DEV=1 (and only that). The SDK skips signature
# verification and auto-talks to the local Inngest CLI dev server. Without
# INNGEST_DEV=1 the /api/inngest route returns 500 with
# "In cloud mode but no signing key found".
INNGEST_DEV=1
#
# Production: REMOVE INNGEST_DEV. Set INNGEST_EVENT_KEY (used by the SDK to
# emit events to Inngest cloud) and INNGEST_SIGNING_KEY (used by /api/inngest
# to verify inbound webhook calls). Get both from inngest.com > your app >
# Manage > Event Keys / Signing Key (per environment).
# INNGEST_EVENT_KEY=your-inngest-event-key
# INNGEST_SIGNING_KEY=your-inngest-signing-key

# Optional. debug | info | warn | error. Defaults: production=info, otherwise=debug.
# LOG_LEVEL=debug

# Instagram OAuth (BO-005).
#
# Required for the Connect-with-Instagram button on /library to work. Without
# these, the OAuth start action redirects to /library with a "not configured"
# error and the user is left with the paste-a-token fallback only.
#
# IG_APP_ID         Your Instagram-app ID from Meta Developer Dashboard. On
#                   most setups this is the same number as your FB app ID.
#                   Find it on the Instagram product page header.
# IG_APP_SECRET     The Instagram-app secret (NOT the main App settings
#                   secret). Click "Show" next to "Instagram-app secret" on
#                   the Instagram product page.
# IG_OAUTH_REDIRECT_URI  Must match EXACTLY a Valid OAuth Redirect URI
#                   registered in Meta dashboard > Instagram > API setup with
#                   Instagram login > step 4 (Business login settings).
#                   Local dev: http://localhost:3000/api/auth/instagram/callback
#                   Prod:      https://your-domain/api/auth/instagram/callback
IG_APP_ID=your-instagram-app-id
IG_APP_SECRET=your-instagram-app-secret
IG_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/instagram/callback

# Optional. Set to 1 to keep the "Paste a token" fallback visible on /library
# in production. Defaults off in prod; always on in dev.
# IG_ALLOW_PASTE_TOKEN=1

# Deepgram transcription (BO-043). Required for the /library "Analyze"
# button on each video tile. Get a key from console.deepgram.com (free
# tier covers ~150 hours of audio).
#
# Operator controls:
#   RESEARCH_ANALYSIS_DISABLED=1     kill switch for the whole feature
#   RESEARCH_ANALYSIS_MAX_PER_30D=N  per-user rolling-30d cap (default 400)
DEEPGRAM_API_KEY=your-deepgram-api-key
# RESEARCH_ANALYSIS_DISABLED=
# RESEARCH_ANALYSIS_MAX_PER_30D=400

# Voyage AI embeddings (BO-049). Powers the client-corpus retrieval surface:
# chat exposes a `search_client_corpus` tool the model calls when the user
# references a specific past artifact (Fathom transcript, weekly
# questionnaire, long-form note); script generation pulls top-k matching
# chunks at gen start.
#
# Get a key from dash.voyageai.com (free tier gives 50M tokens, enough for
# months at typical volume). Model pinned to voyage-3 (1024-d), matching
# the vector(1024) column in migration 20260515000000_client_corpus.sql.
#
# When unset, the chat tool simply isn't registered (no error) and corpus
# retrieval is a no-op. Set this once the corpus is populated.
VOYAGE_API_KEY=your-voyage-api-key

# Weekly check-in (BO-057..BO-060). Two Inngest crons send the Friday
# invitation (09:00 Bali = 01:00 UTC) and Saturday reminder; an Apps
# Script attached to the Google Form POSTs responses to
# /api/weekly-checkin/webhook, signed with WEEKLY_CHECKIN_WEBHOOK_SECRET.
#
# RESEND_API_KEY            From resend.com -> API Keys. When unset, the
#                           email client logs and discards (dry-run) so
#                           local dev never actually mails anyone.
# EMAIL_FROM                "Off&On <weekly@yourdomain.com>". Must be a
#                           verified Resend sender. Required alongside
#                           RESEND_API_KEY for real sends.
# WEEKLY_CHECKIN_FORM_URL   Public viewform URL the cron emails link to.
#                           The Python script at
#                           examples/create_weekly_checkin_form.py writes
#                           this into .env on form creation.
# WEEKLY_CHECKIN_WEBHOOK_SECRET
#                           Shared secret with the Apps Script trigger.
#                           Used to verify HMAC-SHA256 on inbound posts.
# RESEND_API_KEY=
# EMAIL_FROM=
# WEEKLY_CHECKIN_FORM_URL=
# WEEKLY_CHECKIN_WEBHOOK_SECRET=

# GoHighLevel / "Hookd" CRM (BO-075). GHL now owns the weekly check-in:
# its "Off&On Weekly Check-In" survey's *Survey Submitted* workflow has a
# Webhook action that POSTs the answers + contact email to
# /api/ghl/webhook, authenticated by a static shared secret in the
# X-Ghl-Webhook-Secret header. The bot resolves the user by email, saves
# the check-in, and refreshes Voice DNA (reusing the weekly-checkin
# engine). This replaces the bot's own Google-Form/Resend send + reminder
# crons, which are now unregistered.
#
# GHL_WEBHOOK_SECRET   Long random string (>= 32 chars). Set the exact
#                      same value in the GHL Webhook action's custom
#                      header. When unset, /api/ghl/webhook 500s on every
#                      call (fail closed).
# GHL_WEBHOOK_SECRET=

# Apify competitor scraping (BO-062). The "Sync now" button on /research
# starts an Apify actor run; Apify POSTs back to /api/apify/webhook when
# it finishes, authenticated by a static token in X-Apify-Webhook-Token.
#
# APIFY_API_KEY            Personal API token from Apify console >
#                          Settings > Integrations > API tokens. Starts
#                          with apify_api_.
# APIFY_WEBHOOK_SECRET     Shared secret we inject into each actor run's
#                          webhook headers; the route does a constant-
#                          time compare on inbound. Pick any random
#                          string >= 32 chars.
# APIFY_ACTOR_ID           Defaults to apify~instagram-reel-scraper. Set
#                          this only if you want to swap actors.
# APIFY_INSTAGRAM_PROFILE_ACTOR_ID
#                          Defaults to apify~instagram-profile-scraper.
#                          Used by the weekly suggested-avatar refresh
#                          (cron Sunday 05:00 UTC, also triggerable via
#                          research/suggested-avatars.refresh.requested).
# APP_BASE_URL             Public URL prefix the worker uses to build the
#                          webhook callback. On Vercel we fall back to
#                          VERCEL_URL automatically; locally set this to
#                          a tunnel (ngrok / cloudflared) so Apify can
#                          reach you.
# COMPETITOR_SCRAPE_DISABLED=1     kill switch for all scrape requests
APIFY_API_KEY=apify_api_your-token
APIFY_WEBHOOK_SECRET=pick-a-long-random-string
# APIFY_ACTOR_ID=apify~instagram-reel-scraper
# APIFY_INSTAGRAM_PROFILE_ACTOR_ID=apify~instagram-profile-scraper
# APIFY_TIKTOK_ACTOR_ID=clockworks~tiktok-scraper
# APIFY_YOUTUBE_ACTOR_ID=streamers~youtube-scraper
# APIFY_YOUTUBE_DOWNLOADER_ACTOR_ID=streamers~youtube-video-downloader
# APIFY_YOUTUBE_DOWNLOADER_MEMORY_MB=2048  # raise if mp3 extracts OOM
# APP_BASE_URL=https://your-app.vercel.app
# COMPETITOR_SCRAPE_DISABLED=
