# Supabase project — populate from Settings > API in the Supabase dashboard.
# .env.local should hold the real values and is gitignored.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only. Bypasses RLS — never expose to the browser, never NEXT_PUBLIC_-prefix.
# Required for the delete_user_data() RPC when invoked by an admin path.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
